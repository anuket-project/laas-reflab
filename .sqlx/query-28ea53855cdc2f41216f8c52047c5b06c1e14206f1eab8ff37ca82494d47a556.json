  "query": "\n            INSERT INTO flavor_commands (for_flavor, for_image, commands)\n            VALUES ($1, $2, $3)\n            ON CONFLICT (for_flavor, for_image) \n            DO UPDATE SET \n                commands = EXCLUDED.commands\n            RETURNING for_flavor, for_image, commands\n            ",
